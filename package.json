{
  "name": "mcp-server-google-forms",
  "version": "0.4.1",
  "description": "Servidor MCP local para criar, editar e publicar Google Forms a partir do Claude Code",
  "type": "module",
  "license": "MIT",
  "author": "Henrique Alvarenga da Silva",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claude-book/mcp-server-google-forms.git"
  },
